# ─────────────────────────────────────────────────────────────────────────────
# Cadence configuration. EVERYTHING here is optional.
# With no .env at all, Cadence runs in MOCK mode: deterministic settlement,
# no network, no secrets, no chain. `npm start` just works.
# Copy to `.env` only when you want to change the economics or go LIVE.
# ─────────────────────────────────────────────────────────────────────────────

# ── settlement mode ──────────────────────────────────────────────────────────
# mock = deterministic synthetic tx hashes, in-memory ledger (default)
# real = sign EIP-3009 authorizations and submit a batch to Circle Gateway on Arc
CADENCE_SETTLEMENT_MODE=mock

# ── money model ──────────────────────────────────────────────────────────────
# Each listener funds their OWN monthly pool. The pool is divided only across
# the artists that listener actually played — not a global top-40 skim.
CADENCE_MONTHLY_BUDGET_USD=5.0
CADENCE_PER_PLAY_USD=0.002
CADENCE_MIN_PLAY_SECONDS=30

# ── anti-fraud thresholds ────────────────────────────────────────────────────
CADENCE_MAX_PLAYS_PER_HOUR=20
CADENCE_MIN_INTERVAL_SECONDS=5
CADENCE_LOOP_WINDOW_SECONDS=3600

# ── attribution backend (optional) ───────────────────────────────────────────
# With no key, attribution is fully deterministic and offline.
# With a key, hard/ambiguous cases are escalated to a model; on ANY error the
# agent silently falls back to the deterministic path, so it never gets stuck.
ANTHROPIC_API_KEY=
CADENCE_LLM_MODEL=claude-sonnet-4-6

# Resolve metadata from the live MusicBrainz API instead of the bundled cache.
# off = use the bundled data/metadata-cache.json (default, offline)
# on  = query musicbrainz.org for unknown recordings
CADENCE_MUSICBRAINZ=off

# ── on-chain / Circle (only read when CADENCE_SETTLEMENT_MODE=real) ───────────
CADENCE_USDC_ADDRESS=
CADENCE_SPLITTER_ADDRESS=
CADENCE_CHAIN_ID=
CADENCE_RPC_URL=
CADENCE_OPERATOR_PRIVATE_KEY=
CIRCLE_API_KEY=
CIRCLE_GATEWAY_URL=https://api.circle.com/v1/w3s/gateway

# ── server ───────────────────────────────────────────────────────────────────
PORT=3000
