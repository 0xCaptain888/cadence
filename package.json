{
  "name": "cadence",
  "version": "1.0.0",
  "private": true,
  "description": "An autonomous royalty-settlement agent for self-hosted music. Every listen is attributed, weighed for genuine attention, and settled to the right artists in USDC nanopayments on Arc.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "verify": "node scripts/verify-core.mjs",
    "simulate": "node scripts/simulate-plays.mjs",
    "deploy": "node scripts/deploy.mjs",
    "fund": "node scripts/fund-contract.mjs",
    "live-settle": "node scripts/live-settle.mjs",
    "live-full": "node scripts/live-full-settle.mjs"
  },
  "keywords": [
    "usdc",
    "nanopayments",
    "circle",
    "arc",
    "x402",
    "erc-8004",
    "royalties",
    "music",
    "subsonic",
    "navidrome",
    "agent"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "solc": "^0.8.24"
  }
}
